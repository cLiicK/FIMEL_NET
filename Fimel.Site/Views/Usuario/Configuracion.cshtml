@model ConfiguracionUsuarioVM

<input type="hidden" id="hdnURL_GuardarConfiguracion" value='@Url.Action("_GuardarConfiguracion", "Usuario")' />
<input type="hidden" id="hdnURL_ActualizarConfiguracion" value='@Url.Action("_ActualizarConfiguracion", "Usuario")' />
<input type="hidden" id="hdnURL_SubirLogo" value='@Url.Action("_SubirLogo", "Usuario")' />
<input type="hidden" id="hdnURL_GenerarToken" value='@Url.Action("_GenerarTokenPublico", "Usuario")' />
<input type="hidden" id="idConfig" value='@Model.Configuracion.Id' />




<div id="content-wrapper" class="container-9">
	<!--TITULO-->
	<div class="row">
		<div class="col-12">
			<div class="container">
				<div class="row">
					<div class="col-12">
						<h2 class="colorfimel-blue">Mi Configuración</h2>
					</div>
				</div>
			</div>
		</div>
	</div>
	<!--TITULO-->
	<!--Contenido-->
	<div class="row mt-3">
		<div class="col-12 col-md-12 mt-3">

			<div id="divAjustesGenerales">
				<div class="container mt-3">
					<div class="row">
						<div class="col-md-8">
							<div class="accordion" id="accordionFicha">
								<div class="accordion-item">
									<h2 class="accordion-header" id="accordionAjuste-AjustesGenerales-head">
										<button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#accordionFicha-datosPaciente" aria-expanded="true" aria-controls="accordionFicha-datosPaciente">
											General
										</button>
									</h2>
									<div id="accordionFicha-datosPaciente" class="accordion-collapse collapse show" aria-labelledby="accordionFicha-datosPaciente-head">
										<div class="accordion-body">
											<form class="row g-3">
												<div class="col-md-3">
													<label for="inputBloqueHorarioConfig" class="form-label">Duración Bloque Horario</label>
													<select class="form-select" id="inputBloqueHorarioConfig" name="duracion">
														<option value="" selected="selected">Seleccione...</option>
														@if (Model.Configuracion != null)
														{
															@if (Model.Configuracion.DuracionBloqueHorario.ToString() == "00:15:00")
															{<option value="00:15:00" selected="selected">15 minutos</option>}
															else{<option value="00:15:00" >15 minutos</option>}
															@if (Model.Configuracion.DuracionBloqueHorario.ToString() == "00:30:00")
															{<option value="00:30:00" selected="selected">30 minutos</option>}
															else{<option value="00:30:00" >30 minutos</option>}
															@if (Model.Configuracion.DuracionBloqueHorario.ToString() == "00:45:00")
															{<option value="00:45:00" selected="selected">45 minutos</option>}
															else{<option value="00:45:00" >45 minutos</option>}
															@if (Model.Configuracion.DuracionBloqueHorario.ToString() == "01:00:00")
															{<option value="01:00:00" selected="selected">1 Hora</option>}
															else{<option value="01:00:00" >1 Hora</option>}
														}
														else
														{
															<option value="00:15:00">15 Minutos</option>
															<option value="00:30:00">30 Minutos</option>
															<option value="00:45:00">45 Minutos</option>
															<option value="01:00:00">1 Hora</option>
														}
													</select>
												</div>
												<div class="col-md-4">
													<label for="inputDiasAvisoControl" class="form-label">
														D&#237;as de aviso previo al control
														<i class="fas fa-circle-info ms-1 text-muted"
														   data-bs-toggle="tooltip" data-bs-placement="top"
														   title="Correo al paciente N d&#237;as antes de su pr&#243;ximo control. 0 = desactivado."
														   style="cursor:help;"></i>
													</label>
													<input type="number" class="form-control" id="inputDiasAvisoControl" min="0" max="30"
														value="@(Model.Configuracion != null ? Model.Configuracion.DiasAvisoPrevioControl : 5)"
														placeholder="5">
												</div>
											</form>
										</div>
									</div>
								</div>
								@* <div class="accordion-item">
									<h2 class="accordion-header" id="accordionAjuste-CamposPersonalizados-head">
										<button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#accordionFicha-CamposPersonalizados" aria-expanded="true" aria-controls="accordionFicha-CamposPersonalizados">
											Campos Personalizados
										</button>
									</h2>
									<div id="accordionFicha-CamposPersonalizados" class="accordion-collapse collapse show" aria-labelledby="accordionFicha-CamposPersonalizados-head">
										<div class="accordion-body">
											<form class="row g-3">
												<div class="col-md-4">
													<label for="selectTipoCampo" class="form-label">Tipo de Campo Personalizado</label>
													<select class="form-select" id="selectTipoCampo">
														<option value="" selected="selected">Seleccione...</option>
														<option value="text">Texto</option>
														<option value="num">Números</option>
														<option value="date">Fecha</option>
														<option value="time">Hora</option>
													</select>
												</div>

												<div class="col-md-6">
													<label for="inputDescripcionCampo" class="form-label">Descripción del Campo Personalizado</label>
													<input id="inputDescripcionCampo" type="text" class="form-control" placeholder="EJ: N° de Teléfono">
												</div>
											</form>
										</div>
									</div>
								</div> *@
								@* <div class="accordion-item">
									<h2 class="accordion-header" id="accordionGeneral-General-head">
										<button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#accordionConfig-Correo" aria-expanded="true" aria-controls="accordionConfig-Correo">
											Configuración de Correo
										</button>
									</h2>
									<div id="accordionConfig-Correo" class="accordion-collapse collapse show" aria-labelledby="accordionConfig-Correo-head">
										<div class="accordion-body">
											<form class="row g-3">
												<div class="col-md-3">
													<label class="form-label">Asunto</label>
													<input class="form-control" />
												</div>
												<div class="col-md-3">
													<label class="form-label">Cuerpo</label>
													<input class="form-control" />
												</div>
												<div class="col-md-3">
													<label class="form-label">Imagen</label>
													<input class="form-control" />
												</div>
											</form>
										</div>
									</div>
								</div> *@
							</div>

							@if (Model.Usuario.IdPerfil == (int)Fimel.Models.Enums.EnumPerfiles.Especialista ||
								 Model.Usuario.IdPerfil == (int)Fimel.Models.Enums.EnumPerfiles.Administrador)
							{
								string? urlPublica = ViewBag.UrlPublica as string;
								<div class="accordion-item mt-2">
									<h2 class="accordion-header">
										<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#accordionConfig-EnlacePublico" aria-expanded="false">
											Enlace público de agendamiento
										</button>
									</h2>
									<div id="accordionConfig-EnlacePublico" class="accordion-collapse collapse">
										<div class="accordion-body">
											<p class="text-muted" style="font-size:0.88rem">
												Comparte este enlace para que tus pacientes puedan agendar una cita directamente,
												sin necesidad de iniciar sesión.
											</p>
											@if (!string.IsNullOrEmpty(urlPublica))
											{
												<div class="mb-3">
													<label class="form-label fw-semibold">Tu enlace actual</label>
													<div class="input-group">
														<input type="text" class="form-control form-control-sm" id="inputUrlPublica" value="@urlPublica" readonly>
														<button class="btn btn-outline-secondary btn-sm" type="button" onclick="ModuloConfiguracionUsuario.CopiarEnlace()">
															<i class="fas fa-copy"></i>
														</button>
														<a href="@urlPublica" target="_blank" class="btn btn-outline-secondary btn-sm">
															<i class="fas fa-arrow-up-right-from-square"></i>
														</a>
													</div>
												</div>
											}
											<button type="button" class="btn btn-blue btn-sm" id="btnGenerarToken"
												onclick="ModuloConfiguracionUsuario.GenerarEnlace(this)">
												<i class="fas fa-link me-1"></i>
												@(string.IsNullOrEmpty(urlPublica) ? "Generar enlace" : "Regenerar enlace")
											</button>
											@if (!string.IsNullOrEmpty(urlPublica))
											{
												<p class="text-muted mt-2" style="font-size:0.8rem">
													Al regenerar el enlace, el anterior dejará de funcionar.
												</p>
											}
										</div>
									</div>
								</div>
							}
							@if (Model.Usuario.IdPerfil == (int)Fimel.Models.Enums.EnumPerfiles.Especialista ||
								 Model.Usuario.IdPerfil == (int)Fimel.Models.Enums.EnumPerfiles.Administrador)
							{
								string? logoBase64 = ViewBag.LogoBase64 as string;
								<div class="accordion-item mt-2">
									<h2 class="accordion-header">
										<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#accordionConfig-Logo" aria-expanded="false">
											Logo para correos
										</button>
									</h2>
									<div id="accordionConfig-Logo" class="accordion-collapse collapse">
										<div class="accordion-body">
											<p class="text-muted" style="font-size:0.88rem">
												Este logo aparecerá en los correos de cumpleaños enviados a tus pacientes.
												Si no subes uno, se usará el logo de Fimel.
											</p>
											@if (!string.IsNullOrEmpty(logoBase64))
											{
												<div class="mb-3">
													<label class="form-label">Logo actual</label><br>
													<img id="imgLogoActual" src="data:image/png;base64,@logoBase64" alt="Logo actual"
														style="max-height:80px;max-width:220px;border:1px solid #e0e8f0;border-radius:8px;padding:6px;background:#fff">
												</div>
											}
											<div class="mb-3" id="divPreviewNuevoLogo" style="display:none">
												<label class="form-label">Vista previa</label><br>
												<img id="imgPreviewLogo" alt="Vista previa"
													style="max-height:80px;max-width:220px;border:1px solid #e0e8f0;border-radius:8px;padding:6px;background:#fff">
											</div>
											<div class="mb-3">
												<label for="inputLogoFile" class="form-label">@(!string.IsNullOrEmpty(logoBase64) ? "Cambiar logo" : "Subir logo") (PNG o JPG, máx. 2 MB)</label>
												<input type="file" class="form-control" id="inputLogoFile" accept=".png,.jpg,.jpeg">
											</div>
											<button type="button" class="btn btn-blue btn-sm" onclick="ModuloConfiguracionUsuario.SubirLogo(this)">
												<i class="fas fa-upload me-1"></i> Subir logo
											</button>
										</div>
									</div>
								</div>
							}
						</div>
						<!--LATERAL-->
						<div class="col-md-4">
							<div class="accordion" id="accordionFicha">
								<div class="accordion-item">
									<h2 class="accordion-header" id="accordionFicha-datosContacto-head">
										<button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#accordionFicha-datosContacto" aria-expanded="true" aria-controls="accordionFicha-datosContacto">
											Mi Usuario
										</button>
									</h2>
									<div id="accordionFicha-datosContacto" class="accordion-collapse collapse show" aria-labelledby="accordionFicha-datosContacto-head">
										<div class="accordion-body">
											<form class="row g-3">
												<div class="col-md-12 position-relative">
													<label for="" class="form-label">Nombres</label>
													<input type="text" class="form-control" id="inputNombresConfig" value="@Model.Usuario.Nombres @Model.Usuario.ApellidoPaterno" disabled>
													<i class="fas fa-user icon-input-ficha"></i>
												</div>
												<div class="col-md-12 position-relative">
													<label for="" class="form-label">Correo Electrónico</label>
													<input type="text" class="form-control" id="inputCorreoConfig" value="@Model.Usuario.Email" disabled>
													<i class="fas fa-envelope icon-input-ficha"></i>
												</div>
											</form>
										</div>
									</div>
								</div>
							</div>
							<div class="bg-white rounded p-3 text-center">
								@if (Model.Configuracion.Id > 0)
								{
									<button class="btn btn-blue" id="btnActualizarConfigUser" onclick="ModuloConfiguracionUsuario.ActualizarConfiguracion(this)">Actualizar</button>
								}
								else
								{
									<button class="btn btn-blue" id="btnGuardarConfigUser" onclick="ModuloConfiguracionUsuario.GuardarConfiguracion(this)">Guardar</button>
								}
							</div>
						</div>
					</div>
				</div>
			</div>

		</div>

	</div>
	<!--Contenido-->
</div>
@section scripts {
	<script src="~/js/Site/Configuracion_Usuario.js?v=1.0" type="text/javascript"></script>
}