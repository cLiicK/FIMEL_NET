<input type="hidden" id="hdnURL_ObtenerHistorial" value='@Url.Action("ObtenerHistorial", "Pacientes")' />
<input type="hidden" id="hdnURL_EliminarPaciente" value='@Url.Action("EliminarPaciente", "Pacientes")' />
<input type="hidden" id="hdnURL_ObtenerProximosControles" value='@Url.Action("ObtenerProximosControles", "Pacientes")' />
<input type="hidden" id="hdnURL_EnviarCorreoProximoControl" value='@Url.Action("EnviarCorreoProximoControl", "Pacientes")' />

<div id="content-wrapper" class="container-9 w-100">
    <!--TITULO-->
    <div class="row">
        <div class="col-12">
            <div class="container-fluid">
                <div class="row">
                    <div class="col-12">
                        <h2 class="colorfimel-blue"><a class="colorfimel-rosa" href="@Url.Action("FichaPaciente", "Pacientes")"><i class="fas fa-angle-left me-3"></i></a> Historial de Pacientes</h2>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!--TITULO-->

    <!--TABS-->
    <div class="row mt-3">
        <div class="col-12">
            <ul class="nav nav-tabs" id="tabsHistorial" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="tab-pacientes-btn" data-bs-toggle="tab" data-bs-target="#tab-pacientes" type="button" role="tab">
                        <i class="fas fa-users me-1"></i> Pacientes
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tab-controles-btn" data-bs-toggle="tab" data-bs-target="#tab-controles" type="button" role="tab">
                        <i class="fas fa-calendar-check me-1"></i> Próximos Controles
                    </button>
                </li>
            </ul>

            <div class="tab-content mt-3">

                <!--TAB 1: Historial de Pacientes-->
                <div class="tab-pane fade show active" id="tab-pacientes" role="tabpanel">
                    <div class="container">
                        <div class="row div-buscar align-items-center">
                            <div class="col-3 d-flex align-items-center">
                                <label for="inputBusqFechaDesde" class="me-2" style="color: #F89B9B; font-size: 16px; font-family: 'Signika Negative', sans-serif;">
                                    Fecha Desde
                                </label>
                                <input type="date" class="form-control" id="inputBusqFechaDesde">
                            </div>
                            <div class="col-3 d-flex align-items-center">
                                <label for="inputBusqFechaHasta" class="me-2"
                                       style="color: #F89B9B; font-size: 16px; font-family: 'Signika Negative', sans-serif;">
                                    Fecha Hasta
                                </label>
                                <input type="date" class="form-control" id="inputBusqFechaHasta">
                            </div>
                            <div class="col-2 text-center">
                                <button class="btn btn-blue w-100" onclick="ModuloHistorialPaciente.CargarHistorial(this)">Buscar</button>
                            </div>
                            <div class="col-2 text-center">
                                <button class="btn btn-secondary w-100" onclick="ModuloHistorialPaciente.CargarHistorialFull()">Limpiar</button>
                            </div>
                        </div>
                    </div>
                    <div class="container mt-4">
                        <div class="row">
                            <table class="table w-100" id="HistorialTable">
                                <thead class="thead-rosa">
                                    <tr>
                                        <th>Nombre</th>
                                        <th>Rut</th>
                                        <th>Celular</th>
                                        <th>Email</th>
                                        <th>Nacionalidad</th>
                                        <th>Fecha Creacion</th>
                                        <th>N° Doc</th>
                                        <th>&nbsp;</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!--TAB 2: Próximos Controles-->
                <div class="tab-pane fade" id="tab-controles" role="tabpanel">
                    <div class="container">
                        <div class="row div-buscar align-items-center">
                            <div class="col-3 d-flex align-items-center">
                                <label for="inputControlFechaDesde" class="me-2" style="color: #F89B9B; font-size: 16px; font-family: 'Signika Negative', sans-serif;">
                                    Desde
                                </label>
                                <input type="date" class="form-control" id="inputControlFechaDesde">
                            </div>
                            <div class="col-3 d-flex align-items-center">
                                <label for="inputControlFechaHasta" class="me-2" style="color: #F89B9B; font-size: 16px; font-family: 'Signika Negative', sans-serif;">
                                    Hasta
                                </label>
                                <input type="date" class="form-control" id="inputControlFechaHasta">
                            </div>
                            <div class="col-2 text-center">
                                <button class="btn btn-blue w-100" onclick="ModuloHistorialPaciente.CargarBandeja(this)">Buscar</button>
                            </div>
                        </div>
                    </div>
                    <div class="container mt-4">
                        <div class="row">
                            <table class="table w-100" id="BandejaTable">
                                <thead class="thead-rosa">
                                    <tr>
                                        <th>Paciente</th>
                                        <th>Email</th>
                                        <th>Próximo Control</th>
                                        <th>Días Restantes</th>
                                        <th>Motivo Consulta</th>
                                        <th>&nbsp;</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
    <!--/TABS-->
</div>

@section scripts {
    <script src="~/js/Site/Historial_Pacientes.js?v=2.0"></script>
}
