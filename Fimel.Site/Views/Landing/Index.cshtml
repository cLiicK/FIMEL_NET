@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Fimel — Software de Gestión Clínica</title>
    <meta name="description" content="Fimel es el sistema de gestión clínica que simplifica tu consulta médica: pacientes, agenda y consultas en un solo lugar.">
    <link rel="icon" type="image/png" sizes="32x32" href="~/img/favicon-32x32.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600;700&family=Signika+Negative:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap-5/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <style>
        :root {
            --fimel-blue: #0E96CC;
            --fimel-dark: #0a6e96;
            --fimel-light: #e8f7fd;
            --fimel-bg: #F5F7FB;
            --fimel-text: #444444;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Open Sans', sans-serif;
            color: var(--fimel-text);
            background: #fff;
        }

        h1, h2, h3, h4, h5 {
            font-family: 'Signika Negative', sans-serif;
        }

        /* NAVBAR */
        .navbar-fimel {
            background: #fff;
            box-shadow: 0 2px 16px rgba(14,150,204,0.08);
            padding: 14px 0;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .navbar-fimel .nav-logo img {
            height: 38px;
        }

        .navbar-fimel .btn-login {
            background: var(--fimel-blue);
            color: #fff;
            border-radius: 8px;
            padding: 8px 22px;
            font-weight: 600;
            font-size: 0.9rem;
            text-decoration: none;
            transition: background 0.2s;
        }

        .navbar-fimel .btn-login:hover {
            background: var(--fimel-dark);
            color: #fff;
        }

        /* HERO */
        .hero {
            background: linear-gradient(135deg, #f0faff 0%, #e2f4fb 60%, #fff 100%);
            padding: 90px 0 70px;
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            right: -120px;
            top: -80px;
            width: 480px;
            height: 480px;
            background: radial-gradient(circle, rgba(14,150,204,0.12) 0%, transparent 70%);
            border-radius: 50%;
        }

        .hero-badge {
            display: inline-block;
            background: var(--fimel-light);
            color: var(--fimel-blue);
            border-radius: 20px;
            padding: 5px 16px;
            font-size: 0.82rem;
            font-weight: 600;
            margin-bottom: 18px;
            letter-spacing: 0.5px;
        }

        .hero h1 {
            font-size: 2.8rem;
            font-weight: 700;
            color: #1a2a3a;
            line-height: 1.2;
            margin-bottom: 20px;
        }

        .hero h1 span {
            color: var(--fimel-blue);
        }

        .hero p.lead {
            font-size: 1.1rem;
            color: #5a6a7a;
            max-width: 520px;
            line-height: 1.7;
            margin-bottom: 36px;
        }

        .hero .btn-cta {
            background: var(--fimel-blue);
            color: #fff;
            border-radius: 10px;
            padding: 14px 34px;
            font-size: 1rem;
            font-weight: 700;
            text-decoration: none;
            display: inline-block;
            transition: background 0.2s, transform 0.15s;
            box-shadow: 0 4px 18px rgba(14,150,204,0.25);
        }

        .hero .btn-cta:hover {
            background: var(--fimel-dark);
            color: #fff;
            transform: translateY(-2px);
        }

        .hero .btn-outline {
            color: var(--fimel-blue);
            border: 2px solid var(--fimel-blue);
            border-radius: 10px;
            padding: 12px 28px;
            font-size: 1rem;
            font-weight: 600;
            text-decoration: none;
            display: inline-block;
            margin-left: 14px;
            transition: all 0.2s;
        }

        .hero .btn-outline:hover {
            background: var(--fimel-blue);
            color: #fff;
        }

        .hero-mockup {
            background: #fff;
            border-radius: 18px;
            box-shadow: 0 12px 60px rgba(14,150,204,0.15);
            padding: 30px;
            position: relative;
        }

        .hero-mockup .mock-bar {
            display: flex;
            gap: 6px;
            margin-bottom: 18px;
        }

        .mock-dot {
            width: 11px;
            height: 11px;
            border-radius: 50%;
        }

        .mock-dot.red { background: #ff6b6b; }
        .mock-dot.yellow { background: #ffd93d; }
        .mock-dot.green { background: #6bcb77; }

        .mock-content {
            background: var(--fimel-bg);
            border-radius: 10px;
            padding: 20px;
        }

        .mock-stat {
            background: #fff;
            border-radius: 10px;
            padding: 14px 18px;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 14px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        }

        .mock-stat-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            flex-shrink: 0;
        }

        .mock-stat-icon.blue { background: var(--fimel-light); color: var(--fimel-blue); }
        .mock-stat-icon.green { background: #e8fdf0; color: #28a745; }
        .mock-stat-icon.orange { background: #fff4e8; color: #fd7e14; }

        .mock-stat-info p { margin: 0; font-size: 0.78rem; color: #999; }
        .mock-stat-info strong { font-size: 1rem; color: #333; }

        /* TRUSTED */
        .trusted-section {
            background: var(--fimel-bg);
            padding: 30px 0;
            text-align: center;
        }

        .trusted-section p {
            font-size: 0.85rem;
            color: #999;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 16px;
        }

        .trusted-pills {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 12px;
        }

        .trusted-pills span {
            background: #fff;
            border: 1px solid #e0e8f0;
            border-radius: 20px;
            padding: 6px 18px;
            font-size: 0.88rem;
            font-weight: 600;
            color: #5a6a7a;
        }

        /* FEATURES */
        .features-section {
            padding: 90px 0;
        }

        .section-label {
            display: inline-block;
            background: var(--fimel-light);
            color: var(--fimel-blue);
            border-radius: 20px;
            padding: 5px 16px;
            font-size: 0.82rem;
            font-weight: 600;
            margin-bottom: 14px;
        }

        .section-title {
            font-size: 2rem;
            font-weight: 700;
            color: #1a2a3a;
            margin-bottom: 12px;
        }

        .section-subtitle {
            font-size: 1rem;
            color: #6a7a8a;
            max-width: 520px;
            margin: 0 auto 50px;
            line-height: 1.7;
        }

        .feature-card {
            background: #fff;
            border-radius: 16px;
            padding: 32px 28px;
            height: 100%;
            border: 1px solid #edf2f7;
            transition: box-shadow 0.25s, transform 0.2s;
        }

        .feature-card:hover {
            box-shadow: 0 8px 32px rgba(14,150,204,0.12);
            transform: translateY(-4px);
        }

        .feature-icon {
            width: 54px;
            height: 54px;
            background: var(--fimel-light);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            color: var(--fimel-blue);
            margin-bottom: 20px;
        }

        .feature-card h4 {
            font-size: 1.1rem;
            font-weight: 700;
            color: #1a2a3a;
            margin-bottom: 10px;
        }

        .feature-card p {
            font-size: 0.92rem;
            color: #6a7a8a;
            line-height: 1.65;
            margin: 0;
        }

        /* HOW IT WORKS */
        .how-section {
            background: linear-gradient(135deg, #f0faff, #e8f4fb);
            padding: 90px 0;
        }

        .step-item {
            display: flex;
            gap: 20px;
            margin-bottom: 36px;
        }

        .step-number {
            width: 44px;
            height: 44px;
            background: var(--fimel-blue);
            color: #fff;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 1rem;
            flex-shrink: 0;
        }

        .step-content h5 {
            font-size: 1rem;
            font-weight: 700;
            color: #1a2a3a;
            margin-bottom: 6px;
        }

        .step-content p {
            font-size: 0.92rem;
            color: #6a7a8a;
            line-height: 1.6;
            margin: 0;
        }

        .how-visual {
            background: #fff;
            border-radius: 18px;
            padding: 32px;
            box-shadow: 0 8px 40px rgba(14,150,204,0.12);
        }

        .calendar-mock {
            border-radius: 10px;
            overflow: hidden;
            border: 1px solid #edf2f7;
        }

        .calendar-mock .cal-header {
            background: var(--fimel-blue);
            color: #fff;
            padding: 12px 18px;
            font-weight: 600;
            font-size: 0.9rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .calendar-mock .cal-body {
            padding: 16px;
            background: #fafcff;
        }

        .cal-event {
            background: var(--fimel-light);
            border-left: 3px solid var(--fimel-blue);
            border-radius: 6px;
            padding: 8px 12px;
            margin-bottom: 8px;
        }

        .cal-event p { margin: 0; font-size: 0.82rem; color: #4a6a7a; }
        .cal-event strong { font-size: 0.88rem; color: #1a2a3a; }

        /* BENEFITS */
        .benefits-section {
            padding: 90px 0;
            background: #fff;
        }

        .benefit-row {
            display: flex;
            align-items: flex-start;
            gap: 14px;
            margin-bottom: 22px;
        }

        .benefit-check {
            width: 28px;
            height: 28px;
            background: var(--fimel-light);
            color: var(--fimel-blue);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            flex-shrink: 0;
            margin-top: 2px;
        }

        .benefit-text h5 {
            font-size: 0.98rem;
            font-weight: 700;
            color: #1a2a3a;
            margin-bottom: 4px;
        }

        .benefit-text p {
            font-size: 0.9rem;
            color: #6a7a8a;
            margin: 0;
            line-height: 1.55;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        .stat-box {
            background: var(--fimel-bg);
            border-radius: 14px;
            padding: 24px 20px;
            text-align: center;
        }

        .stat-box .stat-num {
            font-size: 2.2rem;
            font-weight: 700;
            color: var(--fimel-blue);
            font-family: 'Signika Negative', sans-serif;
            line-height: 1;
            margin-bottom: 6px;
        }

        .stat-box p {
            font-size: 0.85rem;
            color: #6a7a8a;
            margin: 0;
        }

        /* CTA FINAL */
        .cta-section {
            background: linear-gradient(135deg, var(--fimel-blue) 0%, #0a6e96 100%);
            padding: 90px 0;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .cta-section::before {
            content: '';
            position: absolute;
            left: -80px;
            top: -80px;
            width: 300px;
            height: 300px;
            background: rgba(255,255,255,0.06);
            border-radius: 50%;
        }

        .cta-section::after {
            content: '';
            position: absolute;
            right: -60px;
            bottom: -60px;
            width: 240px;
            height: 240px;
            background: rgba(255,255,255,0.05);
            border-radius: 50%;
        }

        .cta-section h2 {
            font-size: 2.2rem;
            font-weight: 700;
            color: #fff;
            margin-bottom: 16px;
        }

        .cta-section p {
            font-size: 1.05rem;
            color: rgba(255,255,255,0.85);
            max-width: 480px;
            margin: 0 auto 36px;
            line-height: 1.7;
        }

        .cta-section .btn-white {
            background: #fff;
            color: var(--fimel-blue);
            border-radius: 10px;
            padding: 14px 38px;
            font-size: 1rem;
            font-weight: 700;
            text-decoration: none;
            display: inline-block;
            transition: transform 0.15s, box-shadow 0.2s;
            box-shadow: 0 6px 24px rgba(0,0,0,0.15);
        }

        .cta-section .btn-white:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 32px rgba(0,0,0,0.2);
            color: var(--fimel-dark);
        }

        /* FOOTER */
        .footer-landing {
            background: #1a2a3a;
            color: rgba(255,255,255,0.6);
            padding: 40px 0 24px;
        }

        .footer-landing .footer-logo img {
            height: 32px;
            filter: brightness(0) invert(1);
            opacity: 0.85;
            margin-bottom: 10px;
        }

        .footer-landing p {
            font-size: 0.85rem;
            margin: 0;
        }

        .footer-landing .footer-links a {
            color: rgba(255,255,255,0.55);
            text-decoration: none;
            font-size: 0.85rem;
            margin-left: 20px;
            transition: color 0.2s;
        }

        .footer-landing .footer-links a:hover {
            color: #fff;
        }

        .footer-divider {
            border-color: rgba(255,255,255,0.08);
            margin: 24px 0 16px;
        }

        /* CONTACTO BUTTON */
        .btn-contacto {
            background: transparent;
            color: var(--fimel-blue);
            border: 2px solid var(--fimel-blue);
            border-radius: 8px;
            padding: 7px 18px;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            transition: background 0.2s, color 0.2s;
        }

        .btn-contacto:hover {
            background: var(--fimel-blue);
            color: #fff;
        }

        /* RESPONSIVE */
        @@media (max-width: 767px) {
            .hero h1 { font-size: 2rem; }
            .hero .btn-outline { margin-left: 0; margin-top: 12px; }
            .hero-mockup { margin-top: 40px; }
            .section-title { font-size: 1.6rem; }
            .stats-grid { grid-template-columns: 1fr 1fr; }
            .cta-section h2 { font-size: 1.7rem; }
            .footer-landing .footer-links { margin-top: 12px; }
            .footer-landing .footer-links a { margin-left: 0; margin-right: 16px; }
        }
    </style>
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar-fimel">
        <div class="container d-flex justify-content-between align-items-center">
            <a class="nav-logo" href="/landing">
                <img src="~/img/logo1.svg" alt="Fimel">
            </a>
            <div class="d-flex gap-2 align-items-center">
                <button type="button" class="btn-contacto" data-bs-toggle="modal" data-bs-target="#modalContacto">
                    <i class="fas fa-envelope me-1"></i> Contáctanos
                </button>
                <a href="/Login/Login" class="btn-login">
                    <i class="fas fa-right-to-bracket me-1"></i> Ingresar
                </a>
            </div>
        </div>
    </nav>

    <!-- HERO -->
    <section class="hero">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6">
                    <span class="hero-badge"><i class="fas fa-star me-1"></i> Software Clínico Inteligente</span>
                    <h1>Gestiona tu clínica <span>sin complicaciones</span></h1>
                    <p class="lead">
                        Fimel centraliza la ficha del paciente, la agenda y las consultas en una plataforma simple,
                        rápida y diseñada para profesionales de la salud.
                    </p>
                    <a href="/Login/Login" class="btn-cta">
                        Comenzar ahora <i class="fas fa-arrow-right ms-2"></i>
                    </a>
                    <a href="#funcionalidades" class="btn-outline">Ver funcionalidades</a>
                </div>
                <div class="col-lg-6 mt-4 mt-lg-0">
                    <div class="hero-mockup">
                        <div class="mock-bar">
                            <div class="mock-dot red"></div>
                            <div class="mock-dot yellow"></div>
                            <div class="mock-dot green"></div>
                        </div>
                        <div class="mock-content">
                            <div class="mock-stat">
                                <div class="mock-stat-icon blue"><i class="fas fa-users"></i></div>
                                <div class="mock-stat-info">
                                    <p>Pacientes activos</p>
                                    <strong>1,248</strong>
                                </div>
                            </div>
                            <div class="mock-stat">
                                <div class="mock-stat-icon green"><i class="fas fa-calendar-check"></i></div>
                                <div class="mock-stat-info">
                                    <p>Citas hoy</p>
                                    <strong>14 agendadas</strong>
                                </div>
                            </div>
                            <div class="mock-stat">
                                <div class="mock-stat-icon orange"><i class="fas fa-stethoscope"></i></div>
                                <div class="mock-stat-info">
                                    <p>Consultas este mes</p>
                                    <strong>187 atendidas</strong>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- TRUSTED -->
    <div class="trusted-section">
        <div class="container">
            <p>Confiado por profesionales de la salud</p>
            <div class="trusted-pills">
                <span><i class="fas fa-user-doctor me-1"></i> Médicos generales</span>
                <span><i class="fas fa-tooth me-1"></i> Dentistas</span>
                <span><i class="fas fa-brain me-1"></i> Psicólogos</span>
                <span><i class="fas fa-heart-pulse me-1"></i> Especialistas</span>
                <span><i class="fas fa-building me-1"></i> Clínicas</span>
            </div>
        </div>
    </div>

    <!-- FEATURES -->
    <section class="features-section" id="funcionalidades">
        <div class="container">
            <div class="text-center">
                <span class="section-label">Funcionalidades</span>
                <h2 class="section-title">Todo lo que necesitas en un solo lugar</h2>
                <p class="section-subtitle">
                    Herramientas diseñadas para hacer tu día a día más eficiente y la atención al paciente más completa.
                </p>
            </div>
            <div class="row g-4">
                <div class="col-md-6 col-lg-4">
                    <div class="feature-card">
                        <div class="feature-icon"><i class="fas fa-folder-open"></i></div>
                        <h4>Ficha del Paciente</h4>
                        <p>Accede al historial clínico completo de cada paciente: antecedentes, diagnósticos, medicamentos y más, todo organizado y a un clic.</p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="feature-card">
                        <div class="feature-icon"><i class="fas fa-calendar-days"></i></div>
                        <h4>Agenda Inteligente</h4>
                        <p>Gestiona tu horario con una agenda visual e intuitiva. Crea, modifica y cancela citas fácilmente con vista semanal o mensual.</p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="feature-card">
                        <div class="feature-icon"><i class="fas fa-stethoscope"></i></div>
                        <h4>Consultas Detalladas</h4>
                        <p>Registra cada consulta con diagnóstico, tratamiento y observaciones. Crea un historial clínico estructurado y siempre disponible.</p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="feature-card">
                        <div class="feature-icon"><i class="fas fa-envelope"></i></div>
                        <h4>Recordatorios Automáticos</h4>
                        <p>Envía correos automáticos de cumpleaños y recordatorios de citas a tus pacientes para fidelizarlos y reducir inasistencias.</p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="feature-card">
                        <div class="feature-icon"><i class="fas fa-users-gear"></i></div>
                        <h4>Multi-usuario</h4>
                        <p>Define perfiles y permisos para tu equipo. Cada profesional accede solo a la información que necesita, de forma segura.</p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="feature-card">
                        <div class="feature-icon"><i class="fas fa-shield-halved"></i></div>
                        <h4>Datos Seguros</h4>
                        <p>Sesiones protegidas, control de acceso por roles y almacenamiento seguro para que la información de tus pacientes esté siempre resguardada.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- HOW IT WORKS -->
    <section class="how-section">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-5">
                    <span class="section-label">Cómo funciona</span>
                    <h2 class="section-title text-start mb-4">Empieza a usar Fimel en minutos</h2>

                    <div class="step-item">
                        <div class="step-number">1</div>
                        <div class="step-content">
                            <h5>Crea tu cuenta</h5>
                            <p>Registra tu institución y configura tu perfil profesional con los datos de tu consulta o clínica.</p>
                        </div>
                    </div>
                    <div class="step-item">
                        <div class="step-number">2</div>
                        <div class="step-content">
                            <h5>Agrega tus pacientes</h5>
                            <p>Ingresa la ficha de cada paciente con sus datos personales, contacto y antecedentes médicos relevantes.</p>
                        </div>
                    </div>
                    <div class="step-item">
                        <div class="step-number">3</div>
                        <div class="step-content">
                            <h5>Gestiona tu agenda</h5>
                            <p>Configura tu horario disponible y comienza a agendar citas de forma rápida y sin errores.</p>
                        </div>
                    </div>
