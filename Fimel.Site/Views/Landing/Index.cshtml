    <!-- MODAL CONTACTO -->
    <div class="modal fade" id="modalContacto" tabindex="-1" aria-labelledby="modalContactoLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius:16px;border:none;box-shadow:0 16px 60px rgba(14,150,204,0.15)">
                <div class="modal-header" style="border-bottom:1px solid #edf2f7;padding:24px 28px 16px">
                    <h5 class="modal-title" id="modalContactoLabel" style="font-family:'Signika Negative',sans-serif;font-weight:700;color:#1a2a3a">
                        <i class="fas fa-envelope me-2" style="color:var(--fimel-blue)"></i>Contáctanos
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body" style="padding:24px 28px">
                    <div id="contactoAlerta" class="alert d-none mb-3" role="alert"></div>
                    <form id="formContacto">
                        <div class="mb-3">
                            <label class="form-label" style="font-weight:600;font-size:0.9rem;color:#444">Nombre</label>
                            <input type="text" class="form-control" id="contactoNombre" placeholder="Tu nombre" required
                                style="border-radius:8px;border:1px solid #e0e8f0;font-size:0.92rem">
                        </div>
                        <div class="mb-3">
                            <label class="form-label" style="font-weight:600;font-size:0.9rem;color:#444">Correo electrónico</label>
                            <input type="email" class="form-control" id="contactoEmail" placeholder="tu@correo.com" required
                                style="border-radius:8px;border:1px solid #e0e8f0;font-size:0.92rem">
                        </div>
                        <div class="mb-4">
                            <label class="form-label" style="font-weight:600;font-size:0.9rem;color:#444">Mensaje</label>
                            <textarea class="form-control" id="contactoMensaje" rows="4" placeholder="¿En qué podemos ayudarte?" required
                                style="border-radius:8px;border:1px solid #e0e8f0;font-size:0.92rem;resize:none"></textarea>
                        </div>
                        <button type="submit" id="btnEnviarContacto" class="btn w-100"
                            style="background:var(--fimel-blue);color:#fff;border-radius:10px;padding:12px;font-weight:700;font-size:0.95rem;border:none;transition:background 0.2s">
                            <i class="fas fa-paper-plane me-2"></i>Enviar mensaje
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.getElementById('formContacto').addEventListener('submit', async function (e) {
            e.preventDefault();

            const btn = document.getElementById('btnEnviarContacto');
            const alerta = document.getElementById('contactoAlerta');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Enviando...';
            alerta.className = 'alert d-none mb-3';

            const params = new URLSearchParams({
                nombre: document.getElementById('contactoNombre').value,
                email: document.getElementById('contactoEmail').value,
                mensaje: document.getElementById('contactoMensaje').value
            });

            try {
                const resp = await fetch('/Landing/Contacto', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: params
                });
                const data = await resp.json();

                if (data.ok) {
                    alerta.className = 'alert alert-success mb-3';
                    alerta.textContent = '¡Mensaje enviado! Te responderemos a la brevedad.';
                    document.getElementById('formContacto').reset();
                } else {
                    alerta.className = 'alert alert-danger mb-3';
                    alerta.textContent = 'Ocurrió un error al enviar el mensaje. Intenta nuevamente.';
                }
            } catch {
                alerta.className = 'alert alert-danger mb-3';
                alerta.textContent = 'Ocurrió un error al enviar el mensaje. Intenta nuevamente.';
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-paper-plane me-2"></i>Enviar mensaje';
            }
        });
    </script>
